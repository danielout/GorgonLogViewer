    "@tauri-apps/plugin-window-state": "^2.4.1",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.1.10"
  }
