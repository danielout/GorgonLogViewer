{
  "name": "gorgonlogviewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate-reference": "tsx scripts/generate-reference.ts",
    "dev": "tsx scripts/generate-reference.ts && vite",
    "build": "tsx scripts/generate-reference.ts && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
